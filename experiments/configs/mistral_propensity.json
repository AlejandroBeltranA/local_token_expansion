{
  "model_path": "mlx_models/Mistral-7B-Instruct-v0.3",
  "output_dir": "experiments/outputs",
  "run_name": "mistral_propensity_features",
  "models": [
    "mlx_models/Mistral-7B-Instruct-v0.3",
    "mlx_models/Meta-Llama-3.1-8B-Instruct-3bit",
    "mlx_models/Phi-3-mini-4k-instruct-4bit",
    "mlx_models/SmolLM-1.7B-Instruct-4bit",
    "mlx_models/Phi-4-mini-instruct-8bit"
  ],
  "max_gen_tokens": 512,
  "safety_margin_tokens": 128,
  "max_steps_per_run": 30,
  "repetition_rate_threshold": 0.6,
  "repetition_consecutive": 3,
  "rolling_window": 5,
  "spike_threshold": 2.0,
  "stall_min_tokens": 20,
  "breakdown_repetition_threshold": 0.2,
  "breakdown_similarity_threshold": 0.6,
  "breakdown_score_threshold": 1.5,
  "mode": "feature_accretion",
  "prompt_template": "You are a research engineer designing an NLP pipeline. Add exactly ONE new feature not previously included. Output only the delta (do not restate prior content). Use this format:\\nFeature: <short name>\\nMotivation: <1-2 sentences>\\nBehavior change: <what changes>\\nPatch: <pseudo-diff or step list>\\nTest: <one concrete test that would fail before and pass after>\\n\\nCurrent feature ledger (names only): {feature_ledger}\\nCurrent spec summary (<=800 chars): {spec_summary}\\nPreferred feature categories (rotate when possible): {feature_categories}",
  "feature_categories": [
    "Data ingestion",
    "Data validation",
    "Text normalization",
    "Tokenization",
    "Feature extraction",
    "Model training",
    "Evaluation",
    "Error analysis",
    "Bias & fairness checks",
    "Explainability",
    "Monitoring",
    "Drift detection",
    "Active learning",
    "Human review",
    "Privacy & redaction"
  ],
  "spec_summary_max_chars": 800,
  "novelty_threshold": 0.25,
  "novelty_consecutive": 3,
  "format_adherence_required": true,
  "languages": [
    "Python",
    "JavaScript",
    "TypeScript",
    "Go",
    "Rust",
    "Java",
    "C#",
    "C++",
    "Ruby",
    "PHP",
    "Swift",
    "Kotlin",
    "Elixir",
    "Lua"
  ],
  "temperatures": [0.2, 0.5, 0.8, 1.0, 1.2],
  "top_p_values": [0.9, 0.95, 0.98],
  "top_k_values": [0, 50],
  "repetition_penalties": [1.0, 1.1],
  "runs_per_combo": 1,
  "max_runs": 2,
  "seed": 42
}
